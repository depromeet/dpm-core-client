{
	"cli": {
		"version": ">= 16.28.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal"
		},
		"staging": {
			"distribution": "store",
			"env": {
				"APP_ENV": "staging"
			}
		},
		"production": {
			"autoIncrement": true
		}
	},
	"submit": {
		"production": {}
	}
}
